# SSO configuration for external SSO service
SSO_BASE_URL=https://iae-sso.virtualfri.id
SSO_TOKEN_ENDPOINT=/api/v1/auth/token
SSO_JWKS_ENDPOINT=/api/v1/auth/jwks
SSO_CACHE_PREFIX=sso
SSO_JWKS_CACHE_SECONDS=3600

# Optional fallback: JWKS JSON or a single public key PEM. Use only if JWKS endpoint is unreachable.
#SSO_JWKS_JSON={"keys": [...] }
#SSO_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Note: install JWT library with:
# composer require firebase/php-jwt
