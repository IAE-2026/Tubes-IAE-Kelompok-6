%% Tugas 3 IAE - Detail Modul 1
%% Pemetaan JWT SSO Dosen -> Role Lokal Service B
sequenceDiagram
    autonumber
    participant MW as ResolveIaeIdentity
    participant V as JwtVerifier
    participant C as IaeSsoClient
    participant SSO as SSO JWKS (Cloud Dosen)
    participant RM as RoleMapper
    participant DB as users / roles / role_user

    MW->>V: verify(jwt)
    V->>C: jwks()
    C->>SSO: GET /api/v1/auth/jwks (cache)
    SSO-->>C: keys (RS256)
    C-->>V: JWKS
    V->>V: JWT::decode(jwt, keys)<br/>(refresh JWKS sekali bila kid rotasi)
    V-->>MW: klaim {sub, email, role/scope, token_type, profile}

    MW->>RM: provision(klaim)
    RM->>RM: inferTokenType()<br/>resolveRoleName(claim_map -> token_type_map -> default)
    RM->>DB: updateOrCreate user (by iae_subject)
    RM->>DB: firstOrCreate role + syncWithoutDetaching
    DB-->>RM: User + Role lokal
    RM-->>MW: [User, namaRoleLokal]
    note over MW: Hasil dibungkus IaeIdentity<br/>(authenticated, localRole, canPay)
